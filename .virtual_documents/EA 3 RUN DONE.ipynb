# ── Load ───────────────────────────────────────────────────────────────────
data = pd.read_csv(RAW_CSV)

# ── Encode target: M → 1, B → 0 ───────────────────────────────────────────
le = LabelEncoder()
data['diagnosis'] = le.fit_transform(data['diagnosis'])

# ── Drop columns not used as features ─────────────────────────────────────
